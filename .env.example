# -- REQUIRED ----------------------------------------------------------
OPENAI_API_KEY=sk-your-key-here

# -- SERVER ------------------------------------------------------------
PORT=3000
NODE_ENV=development

# -- BEHAVIOUR ---------------------------------------------------------
MOCK_MODE=false
LOG_LEVEL=info
HITL_TIMEOUT_SECONDS=300
MAX_INCIDENTS_IN_MEMORY=500
RISK_AUTO_RESPOND_THRESHOLD=3
CONFIDENCE_AUTO_RESPOND_THRESHOLD=0.75

# -- OPENAI ------------------------------------------------------------
OPENAI_MODEL_PRIMARY=gpt-4o
OPENAI_MODEL_FAST=gpt-4o-mini
MAX_OPENAI_RETRIES=3
OPENAI_RETRY_BASE_DELAY_MS=1000

# -- INTERNAL SERVICES -------------------------------------------------
ML_SERVICE_URL=http://localhost:5001
ML_SERVICE_PORT=5001
INTERNAL_API_KEY=aegis-internal-key-dev
LOG_INGESTOR_WATCH_DIR=./data/logs
